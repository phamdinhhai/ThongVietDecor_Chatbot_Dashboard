# Lấy trong Supabase Dashboard > Project Settings > API
# Dùng ở browser (bắt buộc phải có tiền tố NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# CHỈ dùng ở server (API routes, server components). KHÔNG thêm NEXT_PUBLIC_.
# Đây là key có quyền cao nhất, tuyệt đối không commit hoặc log ra console.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
